enum Role {
    ADMIN
    MEMBER
}

model User{
    id  Int @id @ default(autoincrement())
    name String
    email String @unique
    password  String 
    role Role @default(MEMBER)
    
    transactions Transaction[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    deletedAt DateTime? @db.Timestamptz

    @@map("users")
}
